{
  "name": "bun-readlater-epub",
  "version": "0.1.10",
  "description": "Instapaper-like self-hosted read-later service that converts saved articles into EPUB files inside a dedicated Calibre library.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "test": "bun test",
    "check": "bun test && bun run src/server.ts --help",
    "docker:build": "docker build -t bun-readlater-epub:local .",
    "docker:run": "docker run --rm -p 8788:8788 --env-file .env -v $(pwd)/data:/data -v $(pwd)/books:/books bun-readlater-epub:local"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "imagescript": "^1.3.1",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
