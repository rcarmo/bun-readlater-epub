# Required
READLATER_TOKEN=change-me

# Service
PORT=8788
READLATER_DB_PATH=./data/readlater.db
CALIBRE_ARTICLE_LIBRARY=./data/calibre-articles

# Optional archive/paywall fallback base URL
# Example placeholder pattern used by the current fallback logic:
# ARCHIVE_FALLBACK_BASE_URL=https://archive.example/fetch
ARCHIVE_FALLBACK_BASE_URL=

# Fetch hardening
READLATER_FETCH_TIMEOUT_MS=15000
READLATER_FETCH_MAX_HTML_BYTES=3145728
READLATER_FETCH_RETRIES=2

# Image pipeline defaults
READLATER_IMAGE_MAX_WIDTH=800
READLATER_IMAGE_MAX_HEIGHT=600
